{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'No build needed - static site'",
  "outputDirectory": "vision care/vision care/website-v2",
  "installCommand": "echo 'Skipping npm install'",
  "public": true,
  "routes": [
    {
      "src": "/images/(.*)",
      "headers": { "cache-control": "s-maxage=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/data.json",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/vision care/vision care/website-v2/$1"
    }
  ]
}
